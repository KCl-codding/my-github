/* pages/activity/activity.wxss */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  background-color: #c0e7ff;  /* 导航栏颜色 */
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  font-size: 17px;
  font-weight: 500;
  color: #2c5a7a;  /* 深蓝灰色 */
  line-height: 44px;
}
.nav-title-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  max-width: 70%;
}

.nav-title {
  font-size: 18px;
  font-weight: 500;
  color: #2c5a7a;  /* 深蓝灰色 */
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

/* pages/activity/activity.wxss */
.activity-page {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #e6f4ff;  /* 全局背景色 */
}

/* 活动列表 */
.activity-page-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 活动卡片容器 */
.activity-page-item {
  margin-bottom: 8rpx;
}

/* 头像 */
.publisher-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20%;
  flex-shrink: 0;
  border: 2rpx solid #c0e7ff;  /* 淡蓝色边框 */
}

/* 消息气泡 */
.message-bubble {
  max-width: 80%;
  min-width: 50%;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  position: relative;
}

/* 我的消息气泡（右侧）- 蓝色渐变 */
.my-bubble {
  background: linear-gradient(135deg, #a8d8ff 0%, #7fc9ff 100%);
  color: white;
  margin-right: 16rpx;
  border-top-right-radius: 8rpx;
  box-shadow: 0 4rpx 12rpx rgba(127, 201, 255, 0.25);
}

/* 其他用户的气泡（左侧）- 白色 */
.other-bubble {
  background: #ffffff;
  color: #4a6f8f;  /* 柔和蓝灰色 */
  margin-left: 16rpx;
  border-top-left-radius: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(96, 165, 250, 0.1);
}

/* 活动头部布局 */
.activity-page-header {
  display: flex;
  align-items: flex-start;
}

/* 我的活动头部（头像在右侧） */
.my-header {
  justify-content: flex-end;
}

/* 其他活动头部（头像在左侧） */
.other-header {
  justify-content: flex-start;
}

/* 昵称 */
.publisher-name {
  font-size: 24rpx;
  color: #7aa9c4;  /* 柔和的灰蓝色 */
  margin-bottom: 8rpx;
  display: block;
}

.my-bubble .publisher-name {
  color: rgba(255, 255, 255, 0.7);
}

/* 类型标签 - 蓝紫色渐变 */
.activity-page-type {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 16rpx;
  background: linear-gradient(135deg, #7fc9ff 0%, #5b8eb3 100%);
}

/* 活动内容 */
.activity-page-content {
  margin-bottom: 16rpx;
}

.activity-page-desc,
.activity-page-position,
.activity-page-value {
  display: flex;
  margin-bottom: 12rpx;
  font-size: 28rpx;
  line-height: 1.5;
}

.page-label {
  width: 100rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.my-bubble .page-label {
  color: rgba(255, 255, 255, 0.85);
}

.other-bubble .page-label {
  color: #7aa9c4;  /* 柔和的灰蓝色 */
}

.page-value {
  flex: 1;
  font-weight: 400;
  word-break: break-all;
}

.my-bubble .page-value {
  color: white;
}

.other-bubble .page-value {
  color: #4a6f8f;  /* 柔和蓝灰色 */
}

/* 活动时间 */
.activity-page-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  padding-top: 12rpx;
  text-align: right;
  margin-top: 4rpx;
}

.other-bubble .activity-page-time {
  color: #a8c4d8;  /* 淡蓝灰色 */
  border-top: 1rpx solid #dceefb;
}

/* 空状态 */
.empty-page-state {
  text-align: center;
  padding: 100rpx 0;
  color: #7aa9c4;  /* 柔和的灰蓝色 */
  font-size: 28rpx;
}

/* 新增的样式 */
.activity-scroll-view {
  height: calc(100vh - 44px);
  width: 100%;
}

.bottom-tip {
  text-align: center;
  padding: 20rpx 0 40rpx;
  color: #7aa9c4;  /* 柔和的灰蓝色 */
  font-size: 24rpx;
}

.new-message-tip {
  position: fixed;
  bottom: 120rpx;
  left: 50%;
  transform: translateX(-50%);
  background-color: rgba(44, 90, 122, 0.85);  /* 深蓝灰色半透明 */
  color: white;
  padding: 10rpx 30rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  z-index: 100;
  animation: fadeInUp 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(96, 165, 250, 0.2);
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateX(-50%) translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
}
