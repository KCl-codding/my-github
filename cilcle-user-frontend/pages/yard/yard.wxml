<!-- 可点击遮罩关闭 -->
<loading visible="{{loadingVisible}}" mask="{{true}}" maskClosable="{{true}}" bindclose="onLoadingClose"></loading>

<!-- 登录提示弹窗 -->
<login-tip-popup visible="{{showLoginTip}}" title="发布" desc="发布到广场，召集成员叭~" cancelText="暂不发布" confirmText="立即发布" bind:close="onTipClose" bind:confirm="goto" bind:cancel="onTipCancel" />

<!-- 固定导航栏 -->
<view class="custom-nav" style="padding-top: {{20}}px;">
  <view class="nav-title-wrapper">
    <view class="nav-title">活动广场</view>
  </view>
</view>
<view style="height: 60px;"></view>

<!-- pages/activity/activity.wxml -->
<view class="activity-page">
  <!-- 所有活动统一列表 - 使用 scroll-view 实现滚动 -->
  <scroll-view class="activity-scroll-view" scroll-y scroll-into-view="{{scrollIntoView}}" scroll-top="{{scrollTop}}" scroll-with-animation="{{true}}" bindscroll="onScroll" enhanced="{{true}}" show-scrollbar="{{false}}">
    <view class="activity-page-list" wx:if="{{activityList.length > 0}}">
      <block wx:for="{{activityList}}" wx:key="id" wx:for-index="idx">
        <view class="activity-page-item {{item.isSelf ? 'my-activity' : 'other-activity'}}" id="activity-{{idx}}" bindtap="onActivityItemTap" data-activity="{{item}}">
          <!-- 头像位置通过 isSelf 控制 -->
          <view class="activity-page-header {{item.isSelf ? 'my-header' : 'other-header'}}">
            <!-- 其他用户活动：头像在左侧 -->
            <image wx:if="{{!item.isSelf}}" class="publisher-avatar" src="{{item.userInfo.avatarUrl}}" mode="aspectFill"></image>

            <view class="message-bubble {{item.isSelf ? 'my-bubble' : 'other-bubble'}}">
              <!-- 其他用户活动显示昵称 -->
              <text wx:if="{{!item.isSelf}}" class="publisher-name">{{item.userInfo.nickName}}</text>

              <!-- 类型标签 -->
              <view class="activity-page-type">
                {{item.type}}
              </view>

              <!-- 活动内容 -->
              <view class="activity-page-content">
                <view class="activity-page-desc">
                  <text class="page-label">活动：</text>
                  <text class="page-value">{{item.activity}}</text>
                </view>

                <view class="activity-page-position">
                  <text class="page-label">位置：</text>
                  <text class="page-value">{{item.position}}</text>
                </view>

                <view class="activity-page-value">
                  <text class="page-label">人数：</text>
                  <text class="page-value">{{item.currentCount}}/{{item.value}}人</text>
                </view>
              </view>

              <!-- 发布时间 -->
              <view class="activity-page-time" wx:if="{{item.publishTime}}">
                <text>{{item.formattedTime || item.publishTime}}</text>
              </view>
            </view>

            <!-- 我的活动：头像在右侧 -->
            <image wx:if="{{item.isSelf}}" class="publisher-avatar" src="{{item.userInfo.avatarUrl}}" mode="aspectFill"></image>
          </view>
        </view>
      </block>
      <!-- 底部提示 -->
      <view class="bottom-tip" wx:if="{{activityList.length > 0}}">
        <text>—— 已经没有更多活动了 ——</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-page-state" wx:else>
      <view style="height: 80px;"></view>
      <text>暂无活动</text>
    </view>
  </scroll-view>

  <!-- 新消息提示（可选） -->
  <view class="new-message-tip" wx:if="{{showNewMessageTip}}" bindtap="scrollToBottom">
    <text>▼ 有新活动</text>
  </view>
</view>