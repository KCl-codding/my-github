.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  background-color: #c0e7ff;  /* 保持导航栏颜色 */
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  font-size: 17px;
  font-weight: 500;
  color: #2c5a7a;  /* 深蓝灰色，与背景协调 */
  line-height: 44px;
}

/* 头像网格布局 - 固定每行5个 */
.avatar-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: space-between;
  padding: 0 24rpx;
}

.avatar-item {
  width: calc((100% - 24rpx * 4) / 5);
  aspect-ratio: 1 / 1;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 24rpx;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: transparent;
  border: 4rpx solid;
  box-sizing: border-box;
}

/* 空白占位符 */
.avatar-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: #d9eaff;  /* 浅蓝灰，与背景融合 */
  border: 2rpx dashed #b0d4f0;  /* 柔和蓝灰色虚线 */
  box-sizing: border-box;
}

/* 男性边框 - 保持蓝色调，稍微柔和 */
.gender-border-male {
  border-color: #3b82f6;  /* 明亮但柔和的蓝色 */
}

/* 女性边框 - 保持粉色，与蓝色形成温馨对比 */
.gender-border-female {
  border-color: #f472b6;  /* 柔和的粉红色 */
}

/* 空状态提示 - 全宽显示 */
.empty-tip-full {
  width: 100%;
  text-align: center;
  font-size: 28rpx;
  color: #7aa9c4;  /* 柔和的灰蓝色 */
  padding: 80rpx 0;
}

/* 换一批按钮包裹容器 */
.refresh-btn-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
  padding: 10rpx 0 20rpx 0;
  flex-shrink: 0;
  box-sizing: border-box;
  margin-top: 0;
}

/* 换一批按钮样式 - 使用粉蓝渐变，与整体色系呼应 */
.refresh-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rpx 4rpx;
  min-width: 160rpx;
  min-height: 60rpx;
  background: linear-gradient(135deg, #a8d8ff 0%, #7fc9ff 100%);  /* 蓝色调渐变，更清新 */
  border-radius: 60rpx;
  box-shadow: 0 6rpx 16rpx rgba(127, 201, 255, 0.3);  /* 阴影颜色匹配 */
  transition: all 0.3s ease;
  cursor: pointer;
}

.refresh-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.refresh-icon {
  font-size: 30rpx;
  color: #ffffff;
  margin-right: 8rpx;
  font-weight: 600;
  line-height: 1;
  display: inline-block;
}

.refresh-text {
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 500;
  line-height: 1.4;
  letter-spacing: 1rpx;
}

/* 未登录提示文字样式 - 无边框，可点击 */
.login-guard-text {
  text-align: center;
  padding: 40px 20px;
  font-size: 14px;
  color: #6ea8d4;  /* 柔和的蓝灰色 */
  background-color: transparent;
  letter-spacing: 0.5px;
}

.login-guard-text text {
  display: inline-block;
  padding: 8px 16px;
  border-radius: 20px;
  background-color: rgba(192, 231, 255, 0.3);  /* 半透明导航栏色 */
}

/* 活动列表样式 */
.activity-section {
  margin-top: 40rpx;
  padding: 0 30rpx;
  width: 100%;
  box-sizing: border-box;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #2c5a7a;  /* 深蓝灰色，与导航标题一致 */
  margin-bottom: 30rpx;
  padding-left: 10rpx;
  border-left: 8rpx solid #f472b6;  /* 柔和的粉色作为点缀 */
}

/* 使用 Flex 布局实现两列，确保手机端兼容 */
.activity-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  width: 100%;
  box-sizing: border-box;
}

/* 活动卡片 - 两列布局 */
.activity-card {
  width: calc((100% - 30rpx) / 2);
  margin-bottom: 30rpx;
  position: relative;
  background: #ffffff;  /* 卡片保持白色，更清晰 */
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(96, 165, 250, 0.1);  /* 淡蓝色阴影 */
  transition: transform 0.2s;
  box-sizing: border-box;
}

.activity-card:active {
  transform: scale(0.98);
}

/* 封面图容器 - 保持1:1比例 */
.activity-cover-wrapper {
  position: relative;
  width: 100%;
  padding-top: 100%;
  overflow: hidden;
  background-color: #e6f4ff;  /* 全局背景色作为占位背景 */
}

/* 左上角类型标签 */
.activity-type-tag {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  z-index: 2;
  background: rgba(44, 90, 122, 0.85);  /* 深蓝灰色半透明，更协调 */
  backdrop-filter: blur(10rpx);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 30rpx;
  font-weight: 500;
}

/* 右上角人数标签 */
.activity-people-tag {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  z-index: 2;
  background: rgba(44, 90, 122, 0.85);
  backdrop-filter: blur(10rpx);
  color: #fbbf24;  /* 温暖的金黄色，保持醒目 */
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.people-icon {
  font-size: 24rpx;
}

/* 封面图 - 绝对定位铺满 */
.activity-cover {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: #e6f4ff;  /* 全局背景色 */
}

/* 活动描述 */
.activity-desc {
  padding: 20rpx 16rpx 24rpx;
  font-size: 28rpx;
  color: #4a6f8f;  /* 柔和的蓝灰色，不刺眼 */
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  word-break: break-all;
}

/* 活动卡片 - 两列布局 */
.activity-card {
  width: calc((100% - 30rpx) / 2);
  margin-bottom: 30rpx;
  position: relative;
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(96, 165, 250, 0.1);
  transition: transform 0.2s;
  box-sizing: border-box;
  /* 关键：确保卡片内部可以截断 */
  min-width: 0;
}

/* 活动描述 - 两行省略稳定版 */
.activity-desc {
  padding: 20rpx 16rpx 24rpx;
  font-size: 28rpx;
  color: #4a6f8f;
  line-height: 1.4;
  /* 两行省略 */
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  word-break: break-all;
  /* 关键：限制最大高度 */
  max-height: 78.4rpx;  /* 28rpx * 1.4 * 2 = 78.4rpx */
  /* 备选：确保可以截断 */
  min-width: 0;
}

/* 使用 Flex 布局实现两列，确保手机端兼容 */
.activity-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  width: 100%;
  box-sizing: border-box;
  /* 关键：确保子元素可以截断 */
  min-width: 0;
  overflow: hidden;
}