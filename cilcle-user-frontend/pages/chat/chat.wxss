/* pages/yard/yard.wxss */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  background-color: #c0e7ff;  /* 修改：导航栏颜色 */
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding-left: 32rpx;
}

.nav-back {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 16rpx;
  height: 44px;
  cursor: pointer;
}

.back-icon {
  width: 40rpx;
  height: 40rpx;
}

/* 页面背景 */
page {
  background-color: #e6f4ff;  /* 新增：全局背景色 */
}

/* 加载状态 */
.loading-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #7aa9c4;  /* 修改：柔和的灰蓝色 */
}

/* 用户卡片 - 微信布局：无圆角无阴影 */
.user-card {
  margin: 0;
  border-radius: 0;
  overflow: hidden;
}

/* 横向布局：头像 + 右侧信息 */
.user-info-row {
  display: flex;
  align-items: center;
  padding: 40rpx 32rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #c0e7ff, #a8d8ff);  /* 修改：蓝色渐变背景 */
  flex-shrink: 0;
  border: 2rpx solid #c0e7ff;  /* 新增：淡蓝色边框 */
}

.info-right {
  margin-left: 28rpx;
  flex: 1;
}

/* 用户名 */
.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #2c5a7a;  /* 修改：深蓝灰色 */
  margin-bottom: 8rpx;
  line-height: 1.3;
  background: none;
  -webkit-background-clip: unset;
}

.user-id {
  font-size: 26rpx;
  color: #7aa9c4;  /* 修改：柔和的灰蓝色 */
}

/* 分割线 - 微信简洁风格 */
.divider {
  height: 1rpx;
  background: #dceefb;  /* 修改：淡蓝色 */
  margin: 0 32rpx;
}

/* 信息列表 */
.info-list {
  padding: 20rpx;
}

.info-item {
  display: flex;
  align-items: center;
  padding: 40rpx 40rpx;
}

.info-item:active {
  background-color: #e8f3ff;  /* 修改：淡蓝色高亮 */
}

.info-item:not(:last-child) {
  border-bottom: 1rpx solid #dceefb;  /* 修改：淡蓝色分割线 */
}

.label {
  width: 100rpx;
  font-size: 28rpx;
  color: #5b8eb3;  /* 修改：柔和蓝灰色 */
  font-weight: 500;
}

.value {
  flex: 1;
  font-size: 28rpx;
  color: #4a6f8f;  /* 修改：柔和蓝灰色 */
  word-break: break-all;
}

/* 发消息按钮 - 改为蓝色渐变 */
.message-btn {
  margin: 48rpx 30rpx 56rpx;
  background: linear-gradient(135deg, #a8d8ff 0%, #7fc9ff 100%);  /* 修改：蓝色渐变 */
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  border: none;
  box-shadow: none;
}

.message-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.message-btn::after {
  border: none;
}