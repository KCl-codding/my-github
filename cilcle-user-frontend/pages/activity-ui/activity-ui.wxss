/* 导航栏 - 固定在最顶部 */
.custom-nav {
  position: relative;
  width: 100%;
  background-color: #c0e7ff;  /* 修改：导航栏颜色 */
  z-index: 99;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-left: 32rpx;
  padding-right: 32rpx;
  box-sizing: border-box;
  height: 80px;
  flex-shrink: 0;
  box-shadow: 0 -4rpx 20rpx rgba(96, 165, 250, 0.08);  /* 修改：淡蓝色阴影 */
}

.nav-back {
  position: absolute;
  left: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 16rpx;
  height: 44px;
  cursor: pointer;
  z-index: 10;
}

.back-icon {
  width: 40rpx;
  height: 40rpx;
}

.nav-title-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  max-width: 70%;
}

.nav-title {
  font-size: 18px;
  font-weight: 500;
  color: #2c5a7a;  /* 修改：深蓝灰色 */
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

/* 页面容器 */
.activity-detail-container {
  padding: 20rpx 30rpx;
  background-color: #e6f4ff;  /* 修改：全局背景色 */
  min-height: 100vh;
}

/* 活动标题 */
.activity-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #2c5a7a;  /* 修改：深蓝灰色 */
  margin-bottom: 30rpx;
  line-height: 1.3;
}

/* 信息行 */
.activity-info-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  font-size: 28rpx;
  color: #4a6f8f;  /* 修改：柔和蓝灰色 */
}

.info-label {
  width: 100rpx;
  color: #7aa9c4;  /* 修改：柔和的灰蓝色 */
}

.info-value {
  flex: 1;
  color: #2c5a7a;  /* 修改：深蓝灰色 */
}

/* 费用明细区域 - 卡片样式 */
.activity-pays-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(96, 165, 250, 0.08);  /* 修改：淡蓝色阴影 */
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c5a7a;  /* 修改：深蓝灰色 */
  margin-bottom: 20rpx;
  padding-left: 10rpx;
  border-left: 8rpx solid #7fc9ff;  /* 修改：蓝色左边框 */
}

.pay-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #dceefb;  /* 修改：淡蓝色分割线 */
}

.pay-item:last-child {
  border-bottom: none;
}

.pay-project {
  font-size: 28rpx;
  color: #2c5a7a;  /* 修改：深蓝灰色 */
}

.pay-money {
  font-size: 28rpx;
  color: #ff8a6c;  /* 保留暖色作为金额强调 */
  font-weight: bold;
}

/* 图片展示区域：一行三个小方块 */
.activity-images-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(96, 165, 250, 0.08);  /* 修改：淡蓝色阴影 */
}

.images-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -5rpx;
}

.image-item {
  width: calc(33.3% - 10rpx);
  margin: 5rpx;
  aspect-ratio: 1 / 1;
  background-color: #dceefb;  /* 修改：淡蓝色背景 */
  border-radius: 12rpx;
  overflow: hidden;
}

.grid-image {
  width: 100%;
  height: 100%;
  display: block;
}

/* 底部按钮区域 */
.bottom-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #e6f4ff;  /* 新增：背景色与页面一致 */
  box-shadow: 0 -4rpx 20rpx rgba(96, 165, 250, 0.08);  /* 修改：淡蓝色阴影 */
  z-index: 99;
}

.btn-contact,
.btn-publish {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  line-height: 1;
}

/* 联系按钮 - 改为蓝色边框 */
.btn-contact {
  background-color: #ffffff;
  color: #7fc9ff;  /* 修改：淡蓝色文字 */
  border: 2rpx solid #7fc9ff;  /* 修改：淡蓝色边框 */
}

/* 发布/参与按钮 - 改为蓝色渐变 */
.btn-publish {
  background: linear-gradient(135deg, #a8d8ff 0%, #7fc9ff 100%);  /* 修改：蓝色渐变 */
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(127, 201, 255, 0.3);
}

.btn-icon {
  width: 36rpx;
  height: 36rpx;
}

/* 底部占位，防止按钮遮挡内容 */
.bottom-placeholder {
  height: 140rpx;
}

/* 确保容器可以滚动到底部 */
.activity-detail-container {
  padding: 20rpx 30rpx;
  padding-bottom: 0;
  background-color: #e6f4ff;  /* 修改：全局背景色 */
  min-height: 100vh;
}

/* 人数控制样式 */
.people-count-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.count-control {
  width: 56rpx;
  height: 56rpx;
  background-color: #dceefb;  /* 修改：淡蓝色背景 */
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.count-control.disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

.control-icon {
  font-size: 40rpx;
  font-weight: bold;
  color: #2c5a7a;  /* 修改：深蓝灰色 */
}

.count-input {
  width: 100rpx;
  height: 56rpx;
  text-align: center;
  background-color: #dceefb;  /* 修改：淡蓝色背景 */
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #2c5a7a;  /* 新增：文字颜色 */
}

.max-tip {
  font-size: 26rpx;
  color: #7aa9c4;  /* 修改：柔和的灰蓝色 */
  margin-left: 8rpx;
}