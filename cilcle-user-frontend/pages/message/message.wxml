<!--pages/message/message.wxml-->
<!-- 可点击遮罩关闭 -->
<loading visible="{{loadingVisible}}" mask="{{true}}" maskClosable="{{true}}" bindclose="onLoadingClose"></loading>

<!-- 登录提示弹窗 -->
<login-tip-popup visible="{{showLoginTip}}" title="登录提示" desc="登录后即可享用全部内容" cancelText="暂不登录" confirmText="立即登录" bind:close="onTipClose" bind:confirm="onGoLogin" bind:cancel="onTipCancel" />

<!-- 页面容器 -->
<view class="page-container">
  <view class="custom-nav" style="padding-top: {{20}}px;">
    <view class="nav-title">缘-圈 | 消息</view>
  </view>

  <!-- 可滚动的聊天列表，添加自定义下拉刷新 -->
  <scroll-view 
    scroll-y="true" 
    class="chat-scroll" 
    enhanced="{{true}}" 
    show-scrollbar="{{true}}"
    refresher-enabled="{{true}}"
    refresher-triggered="{{refresherTriggered}}"
    bindrefresherrefresh="onScrollViewRefresh"
    refresher-background="#f5f5f5"
    refresher-default-style="black">
    
    <view class="chat-list" wx:if="{{chat_list && chat_list.length > 0}}">
      <view class="chat-item" wx:for="{{chat_list}}" wx:key="id" bindtap="onChatTap" data-user="{{item}}">
        <!-- 头像区域保持不变 -->
        <view class="avatar-wrapper">
          <block wx:if="{{item.chatType === 'group'}}">
            <group-avatar memberAvatars="{{item.memberAvatars}}" size="96" />
          </block>
          <block wx:else>
            <image class="avatar" src="{{item.avatarUrl}}" mode="aspectFill"></image>
          </block>
          <view class="badge" wx:if="{{item.message > 0}}">
            <text class="badge-text">{{item.message > 99 ? '99+' : item.message}}</text>
          </view>
        </view>

        <!-- 聊天信息 -->
        <view class="chat-info">
          <view class="chat-header">
            <text class="nickname">{{item.nickname || '微信用户'}}</text>
            <text class="time">{{item.last_message.sendTimeFormat || ''}}</text>
          </view>
          <view class="chat-preview">
            <text class="last-message">{{item.last_message.content || ' '}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-chat" wx:else>
      <text class="empty-text">暂无聊天记录</text>
      <text class="empty-tip">去添加好友开始聊天吧</text>
    </view>
  </scroll-view>
</view>