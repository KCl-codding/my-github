/* components/group-avatar/group-avatar.wxss */
.group-avatar-container {
  width: 104rpx;
  height: 104rpx;
  overflow: hidden;
  background-color: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* 每个小头像固定正方形 */
.avatar-small {
  width: 32rpx;
  height: 32rpx;
  display: block;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.avatar-small-bg {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 6rpx;
}

/* 1人布局 */
.grid-1 {
  width: 32rpx;
  height: 32rpx;
}
.grid-1-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

/* 2人布局 */
.grid-2 {
  display: flex;
  flex-direction: row;
  gap: 4rpx;
}
.grid-2-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

/* 3人布局 */
.grid-3 {
  display: flex;
  flex-direction: row;
  gap: 4rpx;
}
.grid-3-right {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.grid-3-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

/* 4人布局 */
.grid-4 {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  width: 68rpx;
  gap: 4rpx;
}
.grid-4 .avatar-small {
  width: 32rpx;
  height: 32rpx;
}
.grid-4-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

/* 5-6人布局：使用3x3网格容器但居中 */
.grid-5-6-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

/* 9人布局：3x3网格 */
.grid-9 {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  width: 104rpx;
  gap: 4rpx;
}
.grid-9 .avatar-small,
.grid-9 .avatar-more {
  width: 32rpx;
  height: 32rpx;
}

/* 更多遮罩 */
.avatar-more {
  position: relative;
}
.more-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 500;
  border-radius: 6rpx;
}

/* 占位符（透明占位） */
.avatar-placeholder {
  background-color: transparent;
}