.mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.tip-popup {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 560rpx;
  z-index: 1001;
}

.popup-content {
  background-color: #e9f6fc;
  border-radius: 32rpx;
  padding: 56rpx 40rpx 40rpx;
  text-align: center;
}

.icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 32rpx;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 48rpx;
}

.btn-group {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.btn-cancel {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #f5f5f5;
  color: #666;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

.btn-cancel::after {
  border: none;
}

.btn-confirm {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #e9f6fc, #cbedfa);
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #fff;
  border: none;
}

.btn-confirm::after {
  border: none;
}