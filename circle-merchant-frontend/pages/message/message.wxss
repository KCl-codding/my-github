/* pages/message/message.wxss */

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  background-color: #cbedfa;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  font-size: 17px;
  font-weight: 500;
  color: #333;
  line-height: 44px;
}

.chat-list {
  background-color: transparent;
}

.chat-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid rgba(233, 30, 99, 0.15);
  transition: background-color 0.2s;
  background-color: transparent;
  position: relative;
}

.chat-item:active {
  background-color: rgba(233, 30, 99, 0.03);
}

/* 关键：头像容器必须设置相对定位 */
.avatar-wrapper {
  position: relative;
  margin-right: 24rpx;
  width: 96rpx;
  height: 96rpx;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: rgba(233, 30, 99, 0.08);
  display: block;
}

/* 角标样式 - 确保显示 */
.badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  background-color: #ff3b30;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  border: 2rpx solid #ffffff;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

.badge-text {
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 500;
  line-height: 1;
}

.chat-info {
  flex: 1;
  overflow: hidden;
}

.chat-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.nickname {
  font-size: 34rpx;
  font-weight: 500;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 400rpx;
}

.time {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
  margin-left: 20rpx;
}

.chat-preview {
  overflow: hidden;
}

.last-message {
  font-size: 28rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.empty-chat {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
  background-color: transparent;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-top: 40rpx;
}

.empty-tip {
  font-size: 28rpx;
  color: #bbb;
  margin-top: 16rpx;
}

/* 测试按钮样式 */
.test-btn {
  margin: 40rpx 32rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e8e 100%);
  color: white;
  border-radius: 48rpx;
  font-size: 28rpx;
  position: fixed;
  bottom: 20rpx;
  left: 32rpx;
  right: 32rpx;
  z-index: 1000;
}