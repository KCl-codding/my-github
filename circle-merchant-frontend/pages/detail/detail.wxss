  line-height: 88rpx;
}

.input-field:focus {
  border-color: #07c160;
  background-color: #fff;
}

/* 针对 input 输入框的 placeholder 样式 */
.input-field::placeholder {
  color: #ccc;
  font-size: 28rpx;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.modal-btn {
  flex: 1;
