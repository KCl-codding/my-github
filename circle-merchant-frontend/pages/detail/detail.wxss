  padding: 32rpx;
  font-size: 32rpx;
  background: none;
  border: none;
  line-height: 1;
  border-radius: 0;
}

.modal-btn.cancel-btn {
  color: #999;
}

.modal-btn.confirm-btn {
  color: #07c160;
  border-left: 1rpx solid #f0f0f0;
  font-weight: 500;
}

.modal-btn::after {
  border: none;
}

.modal-btn:active {
  background-color: #f5f5f5;
}

/* 添加按钮样式 */
.add-pay-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  margin-top: 24rpx;
  background-color: #f8f8f8;
  border-radius: 16rpx;
  transition: all 0.3s ease;
  border: 1rpx dashed #ddd;
}

.add-pay-btn:active {
  background-color: #f0f0f0;
}

.add-icon {
  font-size: 36rpx;
  color: #07c160;
  margin-right: 12rpx;
  font-weight: bold;
}

.add-text {
  font-size: 30rpx;
  color: #07c160;
}

/* 空消费项目提示 */
.empty-pays-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}
