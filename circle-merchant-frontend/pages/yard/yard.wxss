/* pages/yard/yard.wxss */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  background-color: #cbedfa;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  font-size: 17px;
  font-weight: 500;
  color: #333;
  line-height: 44px;
}

.page-content {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 页面根容器 - 设置固定高度和滚动 */
.yard-page {
  position: relative;
  height: 100vh;
  background: transparent;
  overflow: hidden;
}

/* 滚动视图容器 */
.yard-scroll-view {
  height: 100%;
  padding: 24rpx 32rpx;
  box-sizing: border-box;
}

/* 卡片容器 - 半透明磨砂质感，可点击 */
.yard-card {
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(20px);
  border-radius: 32rpx;
  margin-bottom: 28rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
  border: 0.5rpx solid rgba(255, 255, 255, 0.3);
}

/* 点击反馈 */
.yard-card:active {
  transform: scale(0.98);
  opacity: 0.95;
}

/* 头部区域 */
.yard-card-header {
  margin-bottom: 24rpx;
}

.yard-activity-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.yard-activity-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1e293b;
  letter-spacing: -0.5rpx;
  line-height: 1.3;
}

/* 标签组容器 - 横向排列，自动换行 */
.yard-tags-wrap {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
}

/* ========== 类型标签 - 绿色 ========== */
.yard-type-wrap {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(16, 185, 129, 0.12);
  padding: 8rpx 16rpx;
  border-radius: 40rpx;
  width: fit-content;
  border: 0.5rpx solid rgba(16, 185, 129, 0.25);
}

.yard-type-label {
  font-size: 24rpx;
  color: #10b981;
  font-weight: 500;
}

.yard-type-value {
  font-size: 24rpx;
  color: #10b981;
  font-weight: 600;
}

/* ========== 容纳人数标签 - 橙色 ========== */
.yard-capacity-wrap {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(245, 158, 11, 0.12);
  padding: 8rpx 16rpx;
  border-radius: 40rpx;
  width: fit-content;
  border: 0.5rpx solid rgba(245, 158, 11, 0.25);
}

.yard-capacity-label {
  font-size: 24rpx;
  color: #f59e0b;
  font-weight: 500;
}

.yard-capacity-value {
  font-size: 24rpx;
  color: #f59e0b;
  font-weight: 600;
}

/* ========== 用户信息标签 - 紫色 ========== */
.yard-user-info {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(139, 92, 246, 0.12);
  padding: 8rpx 16rpx;
  border-radius: 40rpx;
  width: fit-content;
  border: 0.5rpx solid rgba(139, 92, 246, 0.25);
}

.yard-user-label {
  font-size: 24rpx;
  color: #8b5cf6;
  font-weight: 500;
}

.yard-user-name {
  font-size: 24rpx;
  color: #8b5cf6;
  font-weight: 600;
}

/* 位置区域 - 蓝色调 */
.yard-location-wrap {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(59, 130, 246, 0.05);
  padding: 16rpx 20rpx;
  border-radius: 60rpx;
  width: fit-content;
  margin-bottom: 28rpx;
  border: 0.5rpx solid rgba(59, 130, 246, 0.15);
}

.yard-location-label {
  font-size: 26rpx;
  color: #5a6e8c;
  font-weight: 500;
}

.yard-location-text {
  font-size: 28rpx;
  color: #3b82f6;
  font-weight: 470;
}

/* 支付列表容器 */
.yard-pay-list {
  background: rgba(0, 0, 0, 0.02);
  border-radius: 28rpx;
  margin-bottom: 28rpx;
  border: 0.5rpx solid rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

/* 支付列表头部 - 蓝色 */
.yard-pay-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx 12rpx;
  border-bottom: 0.5rpx solid rgba(59, 130, 246, 0.15);
}

.yard-pay-header-title {
  font-size: 26rpx;
  color: #3b82f6;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.yard-pay-header-num {
  font-size: 24rpx;
  color: #94a3b8;
}

/* 单个支付项 */
.yard-pay-item {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 28rpx 24rpx;
  border-bottom: 0.5rpx solid rgba(0, 0, 0, 0.05);
  transition: background 0.2s;
  gap: 16rpx;
}

.yard-pay-item:last-child {
  border-bottom: none;
}

/* 点击反馈 */
.yard-pay-item:active {
  background: rgba(0, 0, 0, 0.03);
}

/* 左侧：序号 + 项目名称 */
.yard-pay-left {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  flex-shrink: 0;
}

/* 序号样式 - 橙色 */
.yard-pay-index {
  font-size: 28rpx;
  color: #f59e0b;
  font-weight: 600;
  min-width: 48rpx;
}

/* 项目名称 */
.yard-pay-name {
  font-size: 30rpx;
  color: #334155;
  font-weight: 490;
  white-space: nowrap;
}

/* 连接线容器 - 自动填充剩余空间 */
.yard-pay-connect {
  flex: 1;
  overflow: hidden;
  white-space: nowrap;
  min-width: 60rpx;
}

.yard-connect-line {
  font-size: 26rpx;
  color: #cbd5e1;
  letter-spacing: 2rpx;
  font-family: monospace;
  display: inline-block;
  width: 100%;
  white-space: nowrap;
}

/* 金额样式 - 蓝色 */
.yard-pay-amount {
  font-size: 32rpx;
  font-weight: 620;
  color: #3b82f6;
  flex-shrink: 0;
  white-space: nowrap;
}

/* 合计区域 */
.yard-total-wrap {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding-top: 20rpx;
  border-top: 1rpx dashed rgba(0, 0, 0, 0.1);
  margin-top: 8rpx;
}

.yard-total-left {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.yard-total-label {
  font-size: 30rpx;
  color: #5a6e8c;
  font-weight: 600;
}

.yard-total-count {
  font-size: 24rpx;
  color: #94a3b8;
}

.yard-total-right {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.yard-total-currency {
  font-size: 28rpx;
  color: #60a5fa;
  font-weight: 500;
}

.yard-total-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #3b82f6;
  letter-spacing: -0.5rpx;
}

/* 空状态样式 */
.yard-empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
  color: #94a3b8;
  font-size: 30rpx;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20px);
  border-radius: 32rpx;
  margin-top: 40rpx;
}

/* pages/yard/yard.wxss - 新增样式 */

/* 申请上传卡片 - 与空状态样式一致 */
.upload-card {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20px);
  border-radius: 32rpx;
  margin-top: 28rpx;
  margin-bottom: 28rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  transition: all 0.2s ease;
  border: 0.5rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  cursor: pointer;
  position: relative;
}

/* 点击反馈 */
.upload-card:active {
  transform: scale(0.98);
  opacity: 0.9;
  background: rgba(255, 255, 255, 0.85);
}

/* 加号图标 */
.plus-icon {
  font-size: 100rpx;
  font-weight: 300;
  color: #3b82f6;
  line-height: 1;
  margin-bottom: 24rpx;
  display: inline-block;
  width: 120rpx;
  height: 120rpx;
  line-height: 120rpx;
  text-align: center;
  background: rgba(59, 130, 246, 0.12);
  border-radius: 60rpx;
  border: 0.5rpx solid rgba(59, 130, 246, 0.25);
  transition: all 0.2s ease;
}

.upload-card:active .plus-icon {
  background: rgba(59, 130, 246, 0.2);
  transform: scale(1.02);
}

/* 主文字 */
.upload-text {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}

/* 副文字描述 */
.upload-desc {
  display: block;
  font-size: 26rpx;
  color: #94a3b8;
  letter-spacing: 0.5rpx;
}