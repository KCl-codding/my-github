<!-- pages/yard/yard.wxml -->
<!-- 可点击遮罩关闭 -->
<loading visible="{{loadingVisible}}" mask="{{true}}" maskClosable="{{true}}" bindclose="onLoadingClose"></loading>

<!-- 登录提示弹窗 -->
<login-tip-popup 
  visible="{{showLoginTip}}"
  title="登录提示"
  desc="登录后即可享用全部内容"
  cancelText="暂不登录"
  confirmText="立即登录"
  bind:close="onTipClose"
  bind:confirm="onGoLogin"
  bind:cancel="onTipCancel"
/>

<view class="custom-nav" style="padding-top: {{20}}px;">
  <view class="nav-title">缘-圈 商家端</view>
</view>
<!-- 占位 view -->
<view style="height: 80px;"></view> 

<!-- pages/yard/yard.wxml -->
<view class="yard-page">
  <scroll-view scroll-y class="yard-scroll-view">
    <block wx:for="{{yardList}}" wx:key="id">
      <view class="yard-card" data-uuid="{{item.uuid}}" bindtap="viewDetail">
        <!-- 活动头部：活动名称 + 类型 + 容纳人数 + 用户信息 -->
        <view class="yard-card-header">
          <view class="yard-activity-info">
            <text class="yard-activity-name">{{item.activity}}</text>
            <!-- 标签组：类型、容纳人数、用户信息 -->
            <view class="yard-tags-wrap">
              <!-- 类型标签 -->
              <view class="yard-type-wrap" wx:if="{{item.type}}">
                <text class="yard-type-label">类型：</text>
                <text class="yard-type-value">{{item.type}}</text>
              </view>
              <!-- 容纳人数标签 -->
              <view class="yard-capacity-wrap" wx:if="{{item.value}}">
                <text class="yard-capacity-label">容纳人数：</text>
                <text class="yard-capacity-value">{{item.value}}人</text>
              </view>
            </view>
          </view>
        </view>
        
        <!-- 位置信息 -->
        <view class="yard-location-wrap" wx:if="{{item.position}}">
          <text class="yard-location-label">位置：</text>
          <text class="yard-location-text">{{item.position}}</text>
        </view>
        
        <!-- 支付项目列表 - 活动项目与价钱通过点连接 -->
        <view class="yard-pay-list">
          <view class="yard-pay-header">
            <text class="yard-pay-header-title">费用明细</text>
            <text class="yard-pay-header-num">共{{item.pays.length}}项</text>
          </view>
          
          <view 
            class="yard-pay-item" 
            wx:for="{{item.pays}}" 
            wx:key="id" 
            wx:for-item="pay"
            wx:for-index="idx"
          >
            <view class="yard-pay-left">
              <text class="yard-pay-index">{{idx + 1}}.</text>
              <text class="yard-pay-name">{{pay.payProject}}</text>
            </view>
            <view class="yard-pay-connect">
              <text class="yard-connect-line">{{pay.connectLine}}</text>
            </view>
            <text class="yard-pay-amount">¥{{pay.money}}</text>
          </view>
        </view>
        
        <view class="yard-total-wrap">
          <view class="yard-total-left">
            <text class="yard-total-label">合计金额</text>
            <text class="yard-total-count">({{item.pays.length}}项)</text>
          </view>
          <view class="yard-total-right">
            <text class="yard-total-currency">¥</text>
            <text class="yard-total-value">{{item.totalMoney}}</text>
          </view>
        </view>
      </view>
    </block>
    
    <!-- 空状态提示 -->
    <view wx:if="{{yardList.length === 0}}" class="yard-empty-state">
      <text>暂无活动数据</text>
    </view>
    
    <view class="upload-card" bindtap="onUploadRequest">
      <view class="upload-card-content">
        <view class="plus-icon">+</view>
        <text class="upload-text">申请上传</text>
        <text class="upload-desc">点击发布新活动</text>
      </view>
    </view>

    <!-- 占位 view -->
<view style="height: 80px;"></view> 

  </scroll-view>
</view>