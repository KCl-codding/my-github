<!-- 可点击遮罩关闭 -->
<loading visible="{{loadingVisible}}" mask="{{true}}" maskClosable="{{true}}" bindclose="onLoadingClose"></loading>

<!-- 登录提示弹窗 -->
<login-tip-popup visible="{{showLoginTip}}" title="登录提示" desc="登录后即可享用全部内容" cancelText="暂不登录" confirmText="立即登录" bind:close="onTipClose" bind:confirm="onGoLogin" bind:cancel="onTipCancel" />

<!-- 固定导航栏 -->
<view class="custom-nav" style="padding-top: {{20}}px;">
  <view class="nav-back" bindtap="goBack">
    <image class="back-icon" src="/resources/icon/back.png" mode="aspectFit"></image>
  </view>
  <view class="nav-title-wrapper">
    <view class="nav-title">{{type}}</view>
  </view>
</view>

<!-- 修改区域 -->
<view class="edit-area">
  <!-- 昵称：输入框 -->
  <block wx:if="{{type === '昵称'}}">
    <view class="edit-item">
      <input class="input-field" 
             type="text"
             placeholder="请输入昵称" 
             value="{{nicknameInput}}"
             bindinput="onNicknameInput"
             maxlength="20" />
    </view>
  </block>

  <!-- 性别：下拉选择器 -->
  <block wx:if="{{type === '性别'}}">
    <view class="edit-item">
      <picker mode="selector" 
              range="{{genderOptions}}" 
              value="{{genderIndex}}"
              bindchange="onGenderChange">
        <view class="picker-display">
          <text class="{{genderIndex !== -1 ? 'selected' : 'placeholder'}}">
            {{genderIndex !== -1 ? genderOptions[genderIndex] : '请选择性别'}}
          </text>
          <text class="arrow">▼</text>
        </view>
      </picker>
    </view>
  </block>

  <!-- 地区：三级联动选择器 -->
  <block wx:if="{{type === '地区'}}">
    <view class="edit-item">
      <picker mode="region" 
              value="{{regionValue}}" 
              bindchange="onRegionChange">
        <view class="picker-display">
          <text class="{{regionText !== '请选择地区' ? 'selected' : 'placeholder'}}">
            {{regionText}}
          </text>
          <text class="arrow">▼</text>
        </view>
      </picker>
    </view>
  </block>

  <!-- 保存按钮 -->
  <button class="save-btn" bindtap="saveData">保存</button>
</view>